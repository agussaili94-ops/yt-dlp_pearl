<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout" 
    android:layout_width="match_parent" 
    android:layout_height="match_parent" 
    android:orientation="vertical" 
    android:background="@color/bg_main">

    <LinearLayout 
        android:id="@+id/loading_layout" 
        android:layout_width="match_parent" 
        android:layout_height="match_parent" 
        android:gravity="center" 
        android:orientation="vertical" 
        android:visibility="gone">
        <ProgressBar 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:indeterminateTint="@color/accent_blue"/>
        <TextView 
            android:id="@+id/loading_status_text" 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:layout_marginTop="8dp" 
            android:text="Preparing FFmpeg..." 
            android:textColor="@color/text_dark"/>
    </LinearLayout>

    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="0dp" 
        android:layout_weight="1" 
        android:orientation="vertical" 
        android:paddingTop="32dp" 
        android:paddingHorizontal="16dp">

        <LinearLayout 
            android:layout_width="76dp" 
            android:layout_height="76dp" 
            android:layout_gravity="center_horizontal" 
            android:background="@drawable/bg_card_soft_shadow" 
            android:gravity="center" 
            android:layout_marginBottom="8dp">
             <ImageView 
                 android:layout_width="50dp" 
                 android:layout_height="50dp" 
                 android:src="@drawable/logo_app" />
        </LinearLayout>

        <TextView 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="Version : 2026:03:11" 
            android:textAlignment="center" 
            android:textColor="@color/text_light" 
            android:textSize="12sp" />
        <TextView 
            android:id="@+id/active_counter" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="1/1000" 
            android:textAlignment="center" 
            android:textColor="@color/text_dark" 
            android:textSize="18sp" 
            android:layout_marginBottom="24dp"/>

        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:background="@drawable/bg_card_soft_shadow" 
            android:orientation="vertical" 
            android:paddingTop="8dp" 
            android:paddingBottom="12dp" 
            android:layout_marginBottom="20dp">

            <LinearLayout 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                android:orientation="horizontal" 
                android:gravity="center_vertical" 
                android:paddingHorizontal="16dp">

                <LinearLayout 
                    android:layout_width="36dp" 
                    android:layout_height="36dp" 
                    android:background="@drawable/bg_icon_link_light" 
                    android:gravity="center" 
                    android:layout_marginEnd="12dp">
                    <ImageView 
                        android:layout_width="18dp" 
                        android:layout_height="18dp" 
                        android:src="@drawable/ic_link" 
                        android:tint="@color/accent_blue"/>
                </LinearLayout>

                <!-- DIPERBAIKI: Bungkus EditText dan Garis Biru menjadi satu kolom -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText 
                        android:id="@+id/video_url_edit_text" 
                        android:layout_width="match_parent" 
                        android:layout_height="40dp" 
                        android:background="@null" 
                        android:hint="Video / Stream URL" 
                        android:textColorHint="@color/text_light" 
                        android:textColor="@color/text_dark" 
                        android:textSize="15sp" 
                        android:inputType="textUri" 
                        android:maxLines="1" 
                        android:paddingHorizontal="4dp"/>

                    <!-- Garis Biru sekarang akan selalu sama panjang dengan kolom input teks -->
                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1.5dp" 
                        android:background="@color/accent_blue" 
                        android:layout_marginHorizontal="4dp"/>
                </LinearLayout>

                <View 
                    android:layout_width="1dp" 
                    android:layout_height="24dp" 
                    android:background="#E0E0E0" 
                    android:layout_marginStart="8dp" 
                    android:layout_marginEnd="8dp"/>

                <ImageButton 
                    android:id="@+id/download_button" 
                    android:layout_width="36dp" 
                    android:layout_height="36dp" 
                    android:background="@android:color/transparent" 
                    android:src="@drawable/ic_search" 
                    android:scaleType="centerInside" 
                    android:tint="@color/accent_blue"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView 
            android:id="@+id/recycler_view" 
            android:layout_width="match_parent" 
            android:layout_height="0dp" 
            android:layout_weight="1" 
            android:clipToPadding="false" 
            android:paddingBottom="16dp" 
            android:overScrollMode="never" />

        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:gravity="center" 
            android:orientation="vertical" 
            android:layout_marginBottom="16dp">
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Unduh video favoritmu dengan mudah!" 
                android:textColor="@color/text_dark" 
                android:textSize="13sp" />
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Tempel link video atau stream di atas untuk memulai." 
                android:textColor="@color/text_light" 
                android:textSize="11sp" 
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="64dp" 
        android:background="@color/white" 
        android:elevation="20dp" 
        android:orientation="horizontal" 
        android:paddingHorizontal="24dp">
        <LinearLayout 
            android:layout_width="0dp" 
            android:layout_height="match_parent" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center">
            <ImageView 
                android:layout_width="22dp" 
                android:layout_height="22dp" 
                android:src="@drawable/ic_nav_folder" />
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Unduhan" 
                android:textSize="10sp" 
                android:textColor="@color/accent_blue" 
                android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout 
            android:layout_width="0dp" 
            android:layout_height="match_parent" 
            android:layout_weight="1" 
            android:gravity="center|top" 
            android:paddingTop="6dp">
            <ImageView 
                android:layout_width="44dp" 
                android:layout_height="44dp" 
                android:background="@drawable/bg_circle_blue" 
                android:src="@drawable/ic_arrow_down" 
                android:scaleType="centerInside" 
                android:padding="10dp" />
        </LinearLayout>
        <LinearLayout 
            android:layout_width="0dp" 
            android:layout_height="match_parent" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center">
            <ImageView 
                android:layout_width="22dp" 
                android:layout_height="22dp" 
                android:src="@drawable/ic_nav_settings" />
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Pengaturan" 
                android:textSize="10sp" 
                android:textColor="@color/text_light" 
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
